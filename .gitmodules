[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "MCDA"]
	path = MCDA
	url = https://github.com/paterijk/mcda
	shallow = true
	registered = true
[submodule "RXMCDA"]
	path = RXMCDA
	url = https://github.com/paterijk/rxmcda
	shallow = true
	registered = true
